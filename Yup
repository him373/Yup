-- ==========================================
-- TP All Loop - Heartbeat loop
-- ==========================================

local tpLoopOn = false
local tpLoopConn = nil

tpLoopBtn.MouseButton1Click:Connect(function()
    tpLoopOn = not tpLoopOn
    setTPLoopOn(tpLoopOn)
    if tpLoopOn then
        if not tpBypassOn then antistuff() end
        setStatus("🔁  TP Loop ON (Simple)", Color3.fromRGB(255, 80, 80))
        if tpLoopConn then tpLoopConn:Disconnect(); tpLoopConn = nil end

        local index = 1
        local cached = {}
        local refreshTimer = 0

        tpLoopConn = RunService.Heartbeat:Connect(function(dt)
            if not tpLoopOn then return end
            local char = LocalPlayer.Character
            if not char then return end
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if not hrp then return end

            refreshTimer = refreshTimer + dt
            if refreshTimer >= 0.5 or #cached == 0 then
                refreshTimer = 0
                local alive, dead = getSortedPlayers()
                cached = #alive > 0 and alive or dead
                if index > #cached then index = 1 end
            end

            if #cached == 0 then return end
            if index > #cached then index = 1 end

            local target = cached[index]
            local tChar = target and target.Character
            if tChar then
                local tHRP = tChar:FindFirstChild("HumanoidRootPart")
                local tHum = tChar:FindFirstChildOfClass("Humanoid")
                if tHRP and tHum then
                    tpTo(hrp, tHRP, tHum)
                    local tag = isAlive(target) and "[A]" or "[D]"
                    setStatus("🔁 " .. tag .. " " .. target.Name, Color3.fromRGB(255, 100, 100))
                end
            end

            index = index + 1
        end)
    else
        if tpLoopConn then tpLoopConn:Disconnect(); tpLoopConn = nil end
        if not tpBypassOn then unantistuff() end
        workspace.FallenPartsDestroyHeight = -150
        resetChar()
        setStatus("🔁  TP Loop OFF", Color3.fromRGB(150, 150, 150))
    end
end)

