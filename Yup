local ok, err = pcall(function()

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RS = game:GetService("ReplicatedStorage")

local enabled = false
local oldFireServer = nil
local currentRemote = nil

local function hookRemote(remote)
    if currentRemote == remote then return end
    currentRemote = remote

    -- Replace block start
    if typeof(hookfunction) ~= "function" then
        warn("[AutoUppercut] Your executor does not support hookfunction.")
        return
    end

    oldFireServer = hookfunction(remote.FireServer, function(self, ...)
        if enabled and self == currentRemote then
            local char = LocalPlayer.Character
            local m1 = char and char:GetAttribute("CurrentM1") or 0
            if m1 >= 3 then
                return oldFireServer(self, "Up")
            end
        end
        return oldFireServer(self, ...)
    end)
    -- Replace block end

    print("[AutoUppercut] Hooked: " .. remote:GetFullName())
end

-- ── Find and hook the right service for current character ─────
local function setupForChar(char)
    task.wait(0.5)
    local moveset = char:GetAttribute("Moveset")
    if not moveset then
        -- Wait for Moveset attribute
        char:GetAttributeChangedSignal("Moveset"):Wait()
        moveset = char:GetAttribute("Moveset")
    end
    if not moveset then print("[AutoUppercut] No Moveset found") return end

    local services = RS.Knit.Knit.Services
    local svc = services:FindFirstChild(moveset .. "Service")
    if not svc then print("[AutoUppercut] Service not found: " .. moveset .. "Service") return end

    local remote = svc.RE.Activated
    hookRemote(remote)
end

-- Hook on spawn and respawn
LocalPlayer.CharacterAdded:Connect(setupForChar)
if LocalPlayer.Character then
    task.spawn(setupForChar, LocalPlayer.Character)
end

