local function resetChar()
    workspace.FallenPartsDestroyHeight = -150
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")
    if hrp then
        hrp.AssemblyLinearVelocity = Vector3.zero
        hrp.AssemblyAngularVelocity = Vector3.zero
    end
    if hum then hum:ChangeState(Enum.HumanoidStateType.GettingUp) end
end

local function isAlive(player)
    if not player.Character then return false end
    local hum = player.Character:FindFirstChildOfClass("Humanoid")
    return hum ~= nil and hum.Health > 0
end

-- Fire all Activated/RightActivated/Hitbox remotes with target Humanoid
local function fireAllRemotes(targetHum)
    local services = ReplicatedStorage:FindFirstChild("Knit") and ReplicatedStorage.Knit:FindFirstChild("Knit") and ReplicatedStorage.Knit.Knit:FindFirstChild("Services")
    if not services then return end

    for _, svc in ipairs(services:GetChildren()) do
        local re = svc:FindFirstChild("RE")
        if re then
            for _, child in ipairs(re:GetChildren()) do
                if child:IsA("RemoteEvent") and (child.Name:match("Activated") or child.Name:match("RightActivated") or child.Name:match("Hitbox") or child.Name:match("Fire")) then
                    pcall(function()
                        child:FireServer(targetHum)
                    end)
                end
            end
        end
    end
end

local function tpTo(hrp, tHRP, tHum)
    local predicted = tHRP.Position + (tHum.MoveDirection * 0.8 * tHum.WalkSpeed)
    local dest = CFrame.new(predicted - tHRP.CFrame.LookVector * 5, predicted)
    local oldPos = hrp.Position

    if tpBypassOn then unantistuff() end

    workspace.FallenPartsDestroyHeight = 100
    hrp.CFrame = dest

    local disp = dest.Position - oldPos
    if disp.Magnitude > 0.5 then
        hrp.AssemblyLinearVelocity = disp * 60
    end

    -- Fire all relevant remotes with target Humanoid
    local targetHum = tHRP.Parent and tHRP.Parent:FindFirstChildOfClass("Humanoid")
    if targetHum then
        fireAllRemotes(targetHum)
    end

    RunService.Heartbeat:Wait()

    hrp.AssemblyLinearVelocity = Vector3.zero
    hrp.AssemblyLinearVelocity = Vector3.new(math.random(-1,1), 0, math.random(-1,1))
    if tpBypassOn then
        task.wait(0.05)
        antistuff()
    end
    workspace.FallenPartsDestroyHeight = -150
end

local function getSortedPlayers()
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    local alive, dead = {}, {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            if isAlive(p) then table.insert(alive, p)
            else table.insert(dead, p) end
        end
    end
    if hrp then
        table.sort(alive, function(a, b)
            local aH = a.Character and a.Character:FindFirstChild("HumanoidRootPart")
            local bH = b.Character and b.Character:FindFirstChild("HumanoidRootPart")
            if not aH then return false end
            if not bH then return true end
            return (hrp.Position - aH.Position).Magnitude < (hrp.Position - bH.Position).Magnitude
        end)
    end
    return alive, dead
end

-- ==========================================
-- TP Selected - Heartbeat loop
-- ==========================================

local tpSelOn = false
local tpSelConn = nil
local selectedPlayer = nil

local function stopSelLoop()
    tpSelOn = false
    if tpSelConn then tpSelConn:Disconnect(); tpSelConn = nil end
    selectedPlayer = nil
    setTPSelOn(false)
    if not tpBypassOn then unantistuff() end
    workspace.FallenPartsDestroyHeight = -150
    resetChar()
end

local function openPanel()
    panelOpen = true
    PlayerPanel.Visible = true
    for _, c in ipairs(PlayerScroll:GetChildren()) do
        if c:IsA("TextButton") then c:Destroy() end
    end
    local count = 0
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            local alive = isAlive(p)
            local btn = Instance.new("TextButton")
            btn.Size = UDim2.new(1, 0, 0, 38)
            btn.BackgroundColor3 = Color3.fromRGB(16, 16, 32)
            btn.BorderSizePixel = 0
            btn.Text = (alive and "[A] " or "[D] ") .. p.Name
            btn.TextSize = 12
            btn.Font = Enum.Font.GothamBold
            btn.TextColor3 = alive and Color3.fromRGB(100, 255, 100) or Color3.fromRGB(255, 100, 100)
            btn.ZIndex = 22
            btn.Parent = PlayerScroll
            Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)
            btn.MouseButton1Click:Connect(function()
                selectedPlayer = p
                closePanel()
                if tpSelConn then tpSelConn:Disconnect(); tpSelConn = nil end
                tpSelOn = true
                setTPSelOn(true)
                if not tpBypassOn then antistuff() end
                setStatus("TP -> " .. p.Name, Color3.fromRGB(255, 180, 80))
                tpSelConn = RunService.Heartbeat:Connect(function()
                    if not tpSelOn then return end
                    local char = LocalPlayer.Character
                    if not char then return end
                    local hrp = char:FindFirstChild("HumanoidRootPart")
                    if not hrp then return end
                    local tChar = selectedPlayer and selectedPlayer.Character
                    if not tChar then return end
                    local tHRP = tChar:FindFirstChild("HumanoidRootPart")
                    local tHum = tChar:FindFirstChildOfClass("Humanoid")
                    if not tHRP or not tHum then return end
                    tpTo(hrp, tHRP, tHum)
                end)
            end)
            count = count + 1
        end
    end
    PlayerScroll.CanvasSize = UDim2.new(0, 0, 0, count * 42)
end

